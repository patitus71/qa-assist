# ─────────────────────────────────────────────────────────────────
# QA Assist — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to source control.
# ─────────────────────────────────────────────────────────────────

# ── AI (required) ─────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Jira (optional — app works without it) ────────────────────────
# Your Jira Cloud instance URL, e.g. https://yourcompany.atlassian.net
JIRA_BASE_URL=

# Jira user email and API token (create at id.atlassian.com/manage-profile/security/api-tokens)
JIRA_EMAIL=
JIRA_API_TOKEN=

# (Optional) Agile board ID for sprint fetching — find it in your board URL
JIRA_BOARD_ID=

# (Optional) Issue type to use when pushing TC tickets to Jira. Default: Task
# Other values: Test, Story, Sub-task (depends on your Jira project config)
JIRA_TC_ISSUE_TYPE=Task

# ── API Test Environments ─────────────────────────────────────────
# Base URLs for each environment used by the API run page.
# Leave blank for any env you don't use.
DEV_API_URL=
DEV_API_TOKEN=

STAGING_API_URL=
STAGING_API_TOKEN=

UAT_API_URL=
UAT_API_TOKEN=

# ── Zephyr (optional — hides cycle selector if not set) ───────────
# Set ZEPHYR_TYPE to either: scale (Zephyr Scale / Jira Cloud)
#                        or: squad (Zephyr Squad / Jira Server/DC)
ZEPHYR_TYPE=
ZEPHYR_TOKEN=
